# 服务器部署时复制本文件为 deploy/.env 或仓库根目录 .env，并替换所有尖括号说明值。
# 不要提交真实 .env、密钥、token、cookie、密码或其他敏感凭证。

COMPOSE_PROJECT_NAME=feishu-iam
FEISHU_IAM_ROOT=/home/dev/feishu-iam

FEISHU_IAM_IMAGE=dockerhub.it.tangtring.com:80/ai/feishu-iam
FEISHU_IAM_IMAGE_TAG=v1.0.3
APP_VERSION=1.0.3
GIT_COMMIT=local

# 如果服务器部署目录是 Git clone 出来的仓库，upgrade.sh 会默认同步当前分支。
# 纯 docker-compose.yaml + .env + upgrade.sh 的三文件部署目录没有 .git，会自动跳过。
FEISHU_IAM_GIT_REMOTE=git@github.com:wodenwang/feishu-iam.git
FEISHU_IAM_GIT_SYNC=auto
# 如需固定升级到指定分支或 tag，可显式设置；留空时跟随当前分支。
FEISHU_IAM_GIT_REF=

# 默认拉取 Registry 镜像；本地预加载镜像验收时可设置为 never。
FEISHU_IAM_PULL_POLICY=always

HOST_WEB_PORT=8000
CONTAINER_WEB_PORT=3000
FEISHU_IAM_PUBLIC_URL=https://feishu-iam.riversoft.com.cn
FEISHU_IAM_HEALTHCHECK_URL=https://feishu-iam.riversoft.com.cn
ADMIN_WEB_BASE_URL=https://feishu-iam.riversoft.com.cn

POSTGRES_DB=feishu_iam
POSTGRES_USER=feishu_iam
# POSTGRES_PASSWORD 必须与 DATABASE_URL 中的密码片段保持一致。
# 如果密码包含 @:/?#% 等 URL 保留字符，DATABASE_URL 中的密码片段必须做 URL 编码（URL-encoded）。
# 不要在文档或 git 中记录真实数据库密码。
POSTGRES_PASSWORD=<服务器本地强密码>
DATABASE_URL=postgresql://feishu_iam:<服务器本地强密码>@db:5432/feishu_iam?schema=public
POSTGRES_DATA_DIR=${FEISHU_IAM_ROOT}/data/postgres

FEISHU_IAM_CONFIG_DIR=${FEISHU_IAM_ROOT}/config
FEISHU_IAM_LOG_DIR=${FEISHU_IAM_ROOT}/logs
FEISHU_IAM_BACKUP_DIR=${FEISHU_IAM_ROOT}/backups

PLATFORM_ADMIN_TOKEN=<服务器本地平台自动化 token>

# 用于加密第三方应用 client_secret，必须是 32 个字符；生成后应长期稳定保存。
CLIENT_SECRET_ENCRYPTION_KEY=<32字符本地加密密钥>

FEISHU_APP_ID=<飞书企业自建应用 app_id>
FEISHU_APP_SECRET=<飞书企业自建应用 app_secret>
# /api/auth/feishu/callback 仅作为 v1.0.1 兼容旧配置的回调路径保留；新部署必须使用 /oauth/feishu/callback。
FEISHU_OAUTH_REDIRECT_URI=https://feishu-iam.riversoft.com.cn/oauth/feishu/callback
FEISHU_ADMIN_OAUTH_REDIRECT_URI=https://feishu-iam.riversoft.com.cn/admin/auth/feishu/callback

INITIAL_PLATFORM_ADMIN_FEISHU_USER_ID=<王文哲的飞书 user_id>
