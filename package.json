{
  "name": "feishu-iam",
  "private": true,
  "version": "0.4.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "server:dev": "tsx server/src/main.ts",
    "server:build": "tsc -p server/tsconfig.json --noEmit && vite build --ssr server/src/main.ts --outDir dist-server --emptyOutDir && cp -R server/src/db/migrations dist-server/migrations",
    "server:test": "vitest run --config vitest.server.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@ant-design/icons": "6.2.3",
    "@tanstack/react-query": "5.100.13",
    "antd": "6.4.3",
    "fastify": "^5.8.5",
    "pg": "^8.21.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-router-dom": "7.15.1"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.9.1",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "jsdom": "29.1.1",
    "playwright": "1.60.0",
    "tsx": "^4.22.3",
    "typescript": "6.0.3",
    "vite": "8.0.14",
    "vitest": "4.1.7"
  }
}
